# ListenHub SDK — E2E Test Configuration
#
# This file is the template for E2E test environment variables.
# Copy to .env.staging and fill in values, or run `pnpm test:login`
# to populate automatically via interactive browser login.
#
# vitest loads .env.staging automatically when run with --mode staging
# (see package.json test:e2e and test:login scripts).

# API base URL (required)
LISTENHUB_API_URL=https://api.listenhub.ai/api

# Access token (60-day expiry) for authenticated endpoint tests
LISTENHUB_ACCESS_TOKEN=

# Refresh token (30-day expiry) for token refresh tests
LISTENHUB_REFRESH_TOKEN=

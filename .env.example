# ListenHub SDK E2E Test Configuration
# Copy this file to .env.staging or .env and fill in the values
# Or run `pnpm test:login` to populate automatically

# API base URL (required)
LISTENHUB_API_URL=

# Access token (60-day expiry) for authenticated endpoint tests
LISTENHUB_ACCESS_TOKEN=

# Refresh token (30-day expiry) for token refresh tests
LISTENHUB_REFRESH_TOKEN=
